{
  "appId": "com.pentographer.app",
  "productName": "Pentographer",
  "copyright": "Copyright © 2025 Lucas Swartsenburg",
  "directories": {
    "buildResources": "public",
    "output": "dist-app"
  },
  "files": ["dist-electron/**/*", "!node_modules/**/*"],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "app",
      "filter": ["**/*"]
    },
    {
      "from": ".next/static",
      "to": "app/.next/static",
      "filter": ["**/*"]
    },
    {
      "from": "public",
      "to": "app/public",
      "filter": ["**/*"]
    },
    {
      "from": "db/migrations/sqlite",
      "to": "migrations/sqlite",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "icon": "public/favicons/light/icon-512x512.png"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "public/favicons/light/icon-512x512.png"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "category": "Office",
    "icon": "public/favicons/light/icon-512x512.png"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "installerIcon": "public/favicons/light/icon-512x512.png"
  }
}
